# Foundry Knowledge Base — Environment Configuration
# Copy this file to .env and fill in your values.
#
# NOTE: If you used 'azd up' to deploy, most values are loaded automatically
# from .azure/<env>/.env — you only need to set DATA_FOLDER below.

# --- Data Folder ---
# Points to the folder containing your PDFs (in a documents/ subfolder)
DATA_FOLDER=data

# --- Solution Name (optional — defaults to AZURE_ENV_NAME from azd) ---
# SOLUTION_NAME=myproject

# =============================================================================
# AZURE SERVICES — Only needed if NOT using 'azd up'
# If you ran 'azd up', these are loaded from .azure/<env>/.env automatically.
# =============================================================================

# --- Azure AI Foundry ---
# AZURE_AI_AGENT_ENDPOINT=https://your-ai-service.services.ai.azure.com/api/projects/your-project
# AZURE_AI_ENDPOINT=https://your-ai-service.services.ai.azure.com
# AZURE_OPENAI_CHAT_MODEL=gpt-4o-mini
# AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Azure AI Search ---
# AZURE_AI_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
# AZURE_AI_SEARCH_CONNECTION_NAME=search-connection-xxx
